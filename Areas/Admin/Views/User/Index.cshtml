@model UserView
@{
    ViewData["title"] = "|Manage user";
}

<div class="page inset-0 flex flex-col gap-4 overflow-y-auto p-5">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="font-syne text-xl font-bold text-ink">Utilisateurs</h1>
            <p class="mt-0.5 text-xs text-ink-5">@Model.Users.Count() membres — multi-rôles activés</p>
        </div>
        <div class="flex gap-2">
            <button class="rounded-btn flex items-center gap-1.5 border border-ink-7 px-3 py-2 text-xs font-semibold text-ink-4 transition-colors hover:border-ink-6 hover:text-ink">
                <iconify-icon icon="solar:export-linear"></iconify-icon>CSV
            </button>
            <button onclick="openModal('modal-invite')"
                    class="rounded-btn flex items-center gap-1.5 bg-ink px-3 py-2 text-xs font-semibold text-white transition-colors hover:bg-ink-2">
                <iconify-icon icon="solar:user-plus-rounded-linear"></iconify-icon>Inviter
            </button>
        </div>
    </div>

    <div class="grid grid-cols-2 gap-2.5 sm:grid-cols-5">
        <div class="rounded-card shadow-card border border-ink-7 bg-surface p-3">
            <p class="mb-1 font-bold tracking-wider text-[10px] text-ink-5 uppercase">Total</p>
            <p class="font-syne text-xl leading-none font-bold text-ink">
                @Model.Users.Count()
            </p>
        </div>
        <div class="rounded-card shadow-card border border-ink-7 bg-surface p-3">
            <p class="mb-1 font-bold tracking-wider text-[10px] text-violet-500 uppercase">Admins</p>
            <p class="font-syne text-xl leading-none font-bold text-violet-600">
                @Model.Users.Where(u => u.RoleNames.Contains("ADMIN")).Count()
            </p>
        </div>
        <div class="rounded-card shadow-card border border-ink-7 bg-surface p-3">
            <p class="mb-1 font-bold tracking-wider text-[10px] text-blue-500 uppercase">Modérateurs</p>
            <p class="font-syne text-xl leading-none font-bold text-blue-600">
                @Model.Users.Where(u => u.RoleNames.Contains("MODERATOR")).Count()
            </p>
        </div>
        <div class="rounded-card shadow-card border border-ink-7 bg-surface p-3">
            <p class="mb-1 font-bold tracking-wider text-[10px] text-amber-500 uppercase">Marchands</p>
            <p class="font-syne text-xl leading-none font-bold text-amber-600">
                @Model.Users.Where(u => u.RoleNames.Contains("MERCAHNT")).Count()
            </p>
        </div>
        <div class="rounded-card shadow-card border border-ink-7 bg-surface p-3">
            <p class="mb-1 font-bold tracking-wider text-[10px] text-red-500 uppercase">Bannis</p>
            <p class="font-syne text-xl leading-none font-bold text-red-600">
                @Model.Users.Where(u => u.IsBanned).Count()
            </p>
        </div>
    </div>

    <div class="flex flex-wrap items-center gap-2">
        <div class="rounded-btn flex max-w-xs flex-1 items-center gap-2 border border-ink-7 bg-surface px-2 py-2 transition-colors focus-within:border-ink-5">
            <iconify-icon icon="solar:magnifer-linear" class="shrink-0 text-ink-5"></iconify-icon>
            <input type="text" placeholder="Rechercher…" oninput="filterUsers(this.value)"
                   class="w-full bg-transparent text-sm outline-none placeholder:text-ink-5">
        </div>
        <select class="rounded-btn cursor-pointer border border-ink-7 bg-surface px-2 py-2 text-xs font-medium transition-colors outline-none hover:border-ink-5">
            <option>Tous les rôles</option>
            <option>Administrateur</option>
            <option>Modérateur</option>
            <option>Marchand</option>
            <option>Utilisateur</option>
        </select>
        <select class="rounded-btn w-fit cursor-pointer border border-ink-7 bg-surface px-2 py-2 text-xs font-medium transition-colors outline-none hover:border-ink-5">
            <option>Tous statuts</option>
            <option>Actif</option>
            <option>Banni</option>
        </select>
    </div>

    <div class="rounded-card shadow-card min-h-fit border border-ink-7 bg-surface">
        <div class="overflow-x-auto">
            <table class="tbl" id="users-table">
                <thead>
                    <tr>
                        <th><input type="checkbox" class="accent-ink"></th>
                        <th>Utilisateur</th>
                        <th>Rôles</th>
                        <th>Réputation</th>
                        <th>Deals</th>
                        <th>Inscrit le</th>
                        <th>Statut</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody id="users-tbody">
                    @if (Model.Users != null && Model.Users.Any())
                    {
                        foreach (ApplicationUser user in Model.Users)
                        {
                            <tr data-name="Jorvan Kleiv" data-email="jorvan@dealhub.fr">
                                <td><input type="checkbox" class="accent-ink"></td>
                                <td>
                                    <div class="flex items-center gap-2.5">
                                        <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-linear-to-tr from-violet-600 to-violet-400 font-bold text-[10px] text-white uppercase">
                                            @user.FirstName.Substring(0, 1)@user.LastName.Substring(0, 1)
                                        </div>
                                        <div>
                                            <p class="text-sm font-semibold text-ink capitalize">
                                                @user.FirstName @user.LastName
                                            </p>
                                            <p class="text-[10px] text-ink-5">
                                                @user.Email
                                            </p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="flex flex-wrap gap-1">
                                        <span class="rt rt-admin-on"
                                              onclick="toggleRole(this)">
                                            <iconify-icon icon="solar:crown-linear"
                                                          class="text-[10px]"></iconify-icon>Admin
                                        </span><span class="rt rt-modo-off"
                                                     onclick="toggleRole(this)">
                                            <iconify-icon icon="solar:shield-linear"
                                                          class="text-[10px]"></iconify-icon>Modo
                                        </span><span class="rt rt-march-off"
                                                     onclick="toggleRole(this)">
                                            <iconify-icon icon="solar:shop-2-linear"
                                                          class="text-[10px]"></iconify-icon>March.
                                        </span><span class="rt rt-user-off"
                                                     onclick="toggleRole(this)">
                                            <iconify-icon icon="solar:user-linear"
                                                          class="text-[10px]"></iconify-icon>User
                                        </span>
                                    </div>
                                </td>
                                <td class="font-syne text-sm font-bold">
                                    @user.Reputation
                                </td>
                                <td class="text-sm text-ink-4">
                                    @user.Deals.ToList().Count()
                                </td>
                                <td class="text-[10px] text-ink-5">
                                    @user.CreatedAt.ToString("dd - MM - yyyy")
                                </td>
                                <td>
                                    <span class="badge @(user.IsBanned ? "b-banni" : "b-actif")">
                                        @(user.IsBanned ? "Banni" : "Actif")
                                    </span>
                                </td>
                                <td>
                                    <div class="flex gap-1">
                                        <button class="rounded-btn border border-ink-7 px-2 py-1 text-[10px] transition-colors hover:border-ink-5 hover:text-ink"
                                                onclick="openModal('modal-warn-user','Jorvan Kleiv')">
                                            ⚠️
                                        </button><button class="rounded-btn border border-ink-7 px-2 py-1 text-[10px] transition-colors hover:border-ink-5 hover:text-ink"
                                                         onclick="openModal('modal-ban-user','Jorvan Kleiv')">
                                            🔒
                                        </button><button class="rounded-btn border border-ink-7 px-2 py-1 text-[10px] text-red-500 transition-colors hover:border-red-200 hover:bg-red-50"
                                                         onclick="openModal('modal-delete-user','Jorvan Kleiv')">
                                            🗑
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        <div class="flex items-center justify-between border-t border-ink-7 px-4 py-2.5">
            <p class="text-xs text-ink-5">
                Affichage <strong class="text-ink-3">1–5</strong> sur <strong class="text-ink-3">248</strong>
            </p>
            <div class="flex gap-1">
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5 transition-colors hover:bg-ink-8">
                    ←
                </button>
                <button class="rounded bg-ink px-2.5 py-1 text-xs font-semibold text-white">1</button>
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5 transition-colors hover:bg-ink-8">
                    2
                </button>
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5 transition-colors hover:bg-ink-8">
                    3
                </button>
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5">…</button>
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5 transition-colors hover:bg-ink-8">
                    25
                </button>
                <button class="rounded border border-ink-7 px-2.5 py-1 text-xs text-ink-5 transition-colors hover:bg-ink-8">
                    →
                </button>
            </div>
        </div>
        <div id="modal-warn-user" class="modal-wrap hidden">
            <div class="modal-bg" onclick="closeModal('modal-warn-user')"></div>
            <div class="modal-box max-w-md">
                <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-amber-200 bg-amber-50">
                        <iconify-icon icon="solar:danger-triangle-bold" class="text-lg text-amber-500"></iconify-icon>
                    </div>
                    <div class="flex-1">
                        <p class="font-syne text-sm font-bold text-ink">Envoyer un avertissement</p>
                        <p id="warn-name" class="text-xs text-ink-5"></p>
                    </div>
                    <button onclick="closeModal('modal-warn-user')"
                            class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                        ✕
                    </button>
                </div>
                <div class="flex flex-col gap-3 p-5">
                    <div>
                        <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Raison</label><select class="rounded-btn w-full cursor-pointer border border-ink-7 bg-ink-9 px-3 py-2 text-xs outline-none">
                            <option>Contenu inapproprié</option>
                            <option>Spam</option>
                            <option>Comportement abusif</option>
                            <option>Deal frauduleux</option>
                            <option>Autre</option>
                        </select>
                    </div>
                    <div>
                        <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                            Message
                            optionnel
                        </label><textarea rows="3" placeholder="Précisez le motif…"
                                          class="rounded-btn w-full resize-none border border-ink-7 bg-ink-9 px-3 py-2 text-xs transition-colors outline-none placeholder:text-ink-5 focus:border-ink-5"></textarea>
                    </div>
                </div>
                <div class="flex gap-2 px-5 pb-5">
                    <button onclick="closeModal('modal-warn-user')"
                            class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                        Annuler
                    </button>
                    <button onclick="showToast('Avertissement envoyé ✓','orange');closeModal('modal-warn-user')"
                            class="rounded-btn flex-1 bg-amber-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-amber-600">
                        Envoyer
                    </button>
                </div>
            </div>
        </div>

        <div id="modal-ban-user" class="modal-wrap hidden">
            <div class="modal-bg" onclick="closeModal('modal-ban-user')"></div>
            <div class="modal-box max-w-md">
                <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-red-200 bg-red-50">
                        <iconify-icon icon="solar:lock-password-bold" class="text-lg text-red-500"></iconify-icon>
                    </div>
                    <div class="flex-1">
                        <p class="font-syne text-sm font-bold text-ink">Bannir l'utilisateur</p>
                        <p id="ban-name" class="text-xs text-ink-5"></p>
                    </div>
                    <button onclick="closeModal('modal-ban-user')"
                            class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                        ✕
                    </button>
                </div>
                <div class="flex flex-col gap-3 p-5">
                    <div>
                        <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Raison</label><select class="rounded-btn w-full cursor-pointer border border-ink-7 bg-ink-9 px-3 py-2 text-xs outline-none">
                            <option>Comportement abusif répété</option>
                            <option>Spam massif</option>
                            <option>Deal frauduleux</option>
                            <option>Violation des CGU</option>
                        </select>
                    </div>
                    <div>
                        <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Durée</label>
                        <div class="grid grid-cols-4 gap-1.5" id="duree-btns">
                            <button onclick="selectDuree(this)"
                                    class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                                7j
                            </button>
                            <button onclick="selectDuree(this)"
                                    class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                                30j
                            </button>
                            <button onclick="selectDuree(this)"
                                    class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                                90j
                            </button>
                            <button onclick="selectDuree(this)"
                                    class="rounded-btn border border-red-200 bg-red-50 py-2 text-xs font-semibold text-red-600 transition-all hover:bg-red-100">
                                ∞
                            </button>
                        </div>
                    </div>
                    <label class="flex cursor-pointer items-center gap-2 text-xs">
                        <input type="checkbox" checked
                               class="accent-ink">Notifier par email
                    </label>
                </div>
                <div class="flex gap-2 px-5 pb-5">
                    <button onclick="closeModal('modal-ban-user')"
                            class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                        Annuler
                    </button>
                    <button onclick="showToast('Utilisateur banni ✓','red');closeModal('modal-ban-user')"
                            class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600">
                        Confirmer
                    </button>
                </div>
            </div>
        </div>

        <div id="modal-delete-user" class="modal-wrap hidden">
            <div class="modal-bg" onclick="closeModal('modal-delete-user')"></div>
            <div class="modal-box max-w-sm">
                <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                    <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-red-200 bg-red-50">
                        <iconify-icon icon="solar:trash-bin-minimalistic-bold" class="text-lg text-red-500"></iconify-icon>
                    </div>
                    <div class="flex-1">
                        <p class="font-syne text-sm font-bold text-ink">Supprimer le compte</p>
                        <p class="text-xs font-semibold text-red-500">Action irréversible</p>
                    </div>
                    <button onclick="closeModal('modal-delete-user')"
                            class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                        ✕
                    </button>
                </div>
                <div class="flex flex-col gap-3 p-5">
                    <p class="rounded-btn border border-red-100 bg-red-50 px-3 py-2.5 text-xs text-ink-3">
                        Tous les deals,
                        commentaires et données seront définitivement supprimés.
                    </p>
                    <div>
                        <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                            Tapez <strong class="text-ink">SUPPRIMER</strong> pour confirmer
                        </label><input id="del-input" type="text"
                                       oninput="checkDel(this)" placeholder="SUPPRIMER"
                                       class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2 font-mono text-xs transition-colors outline-none placeholder:text-ink-6 focus:border-red-400">
                    </div>
                </div>
                <div class="flex gap-2 px-5 pb-5">
                    <button onclick="closeModal('modal-delete-user')"
                            class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                        Annuler
                    </button>
                    <button id="btn-del" disabled
                            onclick="showToast('Compte supprimé','red');closeModal('modal-delete-user');document.getElementById('del-input').value='';checkDel({value:''})"
                            class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600 disabled:cursor-not-allowed disabled:opacity-30">
                        Supprimer
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

