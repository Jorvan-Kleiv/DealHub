@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div id="view-login" class="animate-fade-in">
    <h1 class="font-title mb-1.5 text-xl font-medium tracking-tight text-gray-900 md:text-2xl">Bon retour</h1>
    <p class="mb-8 text-sm text-gray-500">Connectez-vous pour retrouver vos deals.</p>
    <div class="mb-7 grid grid-cols-1">
        <button type="button" class="flex items-center justify-center gap-2 rounded-xl border border-gray-200 bg-white px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-50/80 hover:text-gray-900 focus:ring-2 focus:ring-gray-200 focus:ring-offset-1 focus:outline-none">
            <iconify-icon icon="logos:google-icon" class="text-base"></iconify-icon>
            Google
        </button>
    </div>

    <div class="relative mb-7 flex items-center">
        <div class="flex-grow border-t border-gray-100"></div>
        <span class="mx-4 flex-shrink-0 text-xs font-medium tracking-wider text-gray-400 uppercase">ou</span>
        <div class="flex-grow border-t border-gray-100"></div>
    </div>
    <form class="flex flex-col gap-4" method="post" id="account">
        <div class="flex flex-col gap-1">
            <div class="relative">
                <input type="email" asp-for="Input.Email" autocomplete="username" id="login-email" class="peer w-full rounded-xl border border-gray-200 bg-transparent px-3.5 pt-5 pb-2 text-sm text-gray-900 placeholder-transparent transition-all outline-none hover:border-gray-300 focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Email" required="">
                <label for="login-email" asp-for="Input.Email" class="pointer-events-none absolute top-2 left-3.5 text-xs text-gray-400 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-gray-500">Adresse email</label>
            </div>
            <span asp-validation-for="Input.Email" class="text-xs text-red-500"></span>
        </div>
        <div class="flex flex-col gap-1">
            <div class="relative">
                <input type="password" asp-for="Input.Password" id="login-password" class="peer w-full rounded-xl border border-gray-200 bg-transparent px-3.5 pt-5 pr-10 pb-2 text-sm text-gray-900 placeholder-transparent transition-all outline-none hover:border-gray-300 focus:border-primary focus:ring-1 focus:ring-primary" placeholder="Mot de passe" required="">
                <label for="login-password" asp-for="Input.Password" class="pointer-events-none absolute top-2 left-3.5 text-xs text-gray-400 transition-all peer-placeholder-shown:top-3.5 peer-placeholder-shown:text-sm peer-focus:top-2 peer-focus:text-xs peer-focus:text-gray-500">Mot de passe</label>
                <button type="button" class="absolute top-3.5 right-3.5 text-gray-400 transition-colors hover:text-gray-700 focus:outline-none" aria-label="Afficher le mot de passe">
                    <iconify-icon icon="solar:eye-linear" stroke-width="1.5" class="text-lg"></iconify-icon>
                </button>
            </div>
            <span asp-validation-for="Input.Password" class="text-xs text-red-500"></span>
        </div>
        <div class="flex items-center justify-between pt-1">
            <div class="flex items-center gap-2">
                <div class="relative flex items-center">
                    <input type="checkbox" asp-for="Input.RememberMe" id="remember" class="peer h-4 w-4 shrink-0 cursor-pointer appearance-none rounded-[4px] border border-gray-300 bg-white transition-all checked:border-primary checked:bg-primary focus:ring-2 focus:ring-primary focus:ring-offset-1 focus:outline-none">
                    <iconify-icon icon="solar:check-read-linear" stroke-width="1.5" class="pointer-events-none absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 text-xs text-white opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
                <label asp-for="Input.RememberMe" class="cursor-pointer text-xs text-gray-500 select-none">Se souvenir de moi</label>
            </div>
            <button type="button" class="text-xs font-medium text-gray-500 transition-colors hover:text-primary">Mot de passe oublié ?</button>
        </div>

        <div class="w-full">
            <button type="submit" class="w-full rounded-xl bg-primary px-4 py-3 text-sm font-medium text-white shadow-sm transition-all hover:bg-[#e63e00] focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:outline-none active:scale-[0.98]">
                Se connecter
            </button>
        </div>
    </form>
    <p class="mt-8 text-center text-sm text-gray-500">
        Pas encore de compte ? <a class="font-medium text-gray-900 transition-colors hover:text-primary" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">S'inscrire</a>
    </p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

