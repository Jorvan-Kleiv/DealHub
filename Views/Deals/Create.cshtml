@model DealHub.Models.DealRequest
@{
    ViewData["Title"] = "Publier un deal";
    Layout = "_Layout";
}

<div class="flex min-h-screen flex-col items-end gap-6 bg-canvas px-4">
    <div class="mx-auto flex w-4xl max-w-4xl flex-col self-start">
        <a asp-action="Index"
           class="group mb-5 inline-flex items-center gap-1.5 text-xs text-ink-4 transition-colors hover:text-ink">
            <svg class="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5"
                 fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 3L5 8l5 5" />
            </svg>
            Retour à la liste
        </a>

        <div class="flex items-center gap-3">
            <span class="rounded-card shadow-card flex h-9 w-9 items-center justify-center bg-brand text-white">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
            </span>
            <div>
                <h1 class="font-syne text-xl leading-none font-semibold text-ink">Publier un deal</h1>
                <p class="mt-0.5 text-xs text-ink-5">Renseignez les informations du bon plan</p>
            </div>
        </div>
    </div>
    <div class="mx-auto w-4xl max-w-4xl">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly"
                 class="rounded-card mb-5 hidden items-start gap-2 border border-red-200 bg-red-50 px-4 py-3 text-xs text-red-700 [&:not(:empty)]:flex">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 8v4m0 4h.01" />
                </svg>
                <span></span>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Informations principales
                </p>
                <div class="mb-4">
                    <label asp-for="Deal.Title"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Titre
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <input asp-for="Deal.Title"
                           placeholder="Ex : AirPods Pro 2 à -40%…"
                           class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink transition-all
                        placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    <span asp-validation-for="Deal.Title" class="mt-1 flex items-center gap-1 text-xs text-red-500"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Deal.Description"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Description
                    </label>
                    <textarea asp-for="Deal.Description"
                              rows="3"
                              placeholder="Décrivez le deal, les conditions, la date de fin…"
                              class="rounded-btn w-full resize-none border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink
                           transition-all placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none"></textarea>
                    <span asp-validation-for="Deal.Description" class="mt-1 text-xs text-red-500"></span>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Liens &amp; médias
                </p>
                <div class="mb-4">
                    <label asp-for="Deal.Url"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        URL du deal
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute top-1/2 left-3 -translate-y-1/2 text-ink-4">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M14.828 14.828a4 4 0 015.656 0l-4-4a4 4 0 00-5.656 5.656l-1.1 1.1" />
                            </svg>
                        </span>
                        <input asp-for="Deal.Url"
                               type="url"
                               placeholder="https://…"
                               class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-9 text-sm text-ink transition-all
                          placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    </div>
                    <span asp-validation-for="Deal.Url" class="mt-1 text-xs text-red-500"></span>
                </div>
                <div>
                    <label class="mb-1.5 block font-semibold text-[11px] text-ink-3">Image du deal</label>
                    <label for="imageFile" id="uploadZone"
                           class="relative flex h-36 w-full cursor-pointer flex-col items-center justify-center gap-2 overflow-hidden rounded-xl border-2 border-dashed border-ink-6 bg-ink-9 transition hover:border-brand hover:bg-brand/[.04]">
                        <div id="uploadPlaceholder" class="pointer-events-none flex flex-col items-center gap-1.5 text-ink-4 transition">
                            <iconify-icon icon="solar:upload-linear" style="font-size:28px;"></iconify-icon>
                            <span class="font-medium text-[11px]">Cliquez ou glissez une image</span>
                            <small class="text-[10px] text-ink-5">PNG, JPG, WEBP — max 5 Mo</small>
                        </div>
                        <img id="imgPreview" class="absolute inset-0 hidden h-full w-full rounded-[10px] object-cover" src="" alt="Aperçu" />
                    </label>
                    <input type="file" id="imageFile" name="ImageFile"
                           accept="image/png,image/jpeg,image/webp,image/gif"
                           class="sr-only" />
                    <div id="fileInfo" class="mt-2 hidden items-center justify-between gap-2 rounded-lg border border-ink-7 bg-ink-8 px-2.5 py-1.5">
                        <div class="flex min-w-0 items-center gap-1.5 text-ink-3">
                            <iconify-icon icon="solar:gallery-linear" class="flex-shrink-0 text-brand" style="font-size:14px;"></iconify-icon>
                            <span id="fileName" class="truncate text-[11px]"></span>
                        </div>
                        <button type="button" id="removeFile" class="flex rounded p-0.5 text-ink-4 transition hover:text-red-500">
                            <iconify-icon icon="solar:close-circle-linear" style="font-size:15px;"></iconify-icon>
                        </button>
                    </div>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Prix
                </p>

                <div class="mb-4 grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Deal.OriginalPrice"
                               class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix original
                            <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute top-1/2 left-3 -translate-y-1/2 text-sm font-semibold text-ink-4">FCFA</span>
                            <input asp-for="Deal.OriginalPrice"
                                   type="number" min="0" step="0.01"
                                   placeholder="0.00"
                                   id="priceOriginal"
                                   class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-7 text-sm text-ink transition-all
                            placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                        </div>
                        <span asp-validation-for="Deal.OriginalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="Deal.FinalPrice"
                               class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix deal
                            <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute top-1/2 left-3 -translate-y-1/2 text-sm font-semibold text-ink-4">FCFA</span>
                            <input asp-for="Deal.FinalPrice"
                                   type="number" min="0" step="0.01"
                                   placeholder="0.00"
                                   id="priceFinal"
                                   class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-7 text-sm text-ink transition-all
                            placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                        </div>
                        <span asp-validation-for="Deal.FinalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                </div>
                <div id="discountBadge"
                     class="rounded-badge hidden w-fit items-center gap-2 border border-brand/20 bg-brand/8 px-3 py-2">
                    <svg class="h-3.5 w-3.5 text-brand" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M7 7h.01M7 3h5.586a1 1 0 01.707.293L17 7l-4 4" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9 9 9-9" />
                    </svg>
                    <span id="discountText" class="text-xs font-bold text-brand"></span>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-6 border border-ink-7 bg-surface p-6">
                <div class="mb-4">
                    <label asp-for="Deal.CategoryId"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Catégorie
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="Deal.CategoryId"
                                asp-items="@(new SelectList(Model.Categories, "Id", "Name"))"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>
                <div>
                    <label asp-for="Deal.MerchantId"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Marchand
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="Deal.MerchantId"
                                asp-items="@(new SelectList(Model.Merchants, "Id", "Name"))"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>
            </div>
            <div class="flex items-center justify-between gap-3">
                <a asp-action="Index"
                   class="rounded-btn border border-ink-7 px-4 py-2.5 text-sm font-semibold text-ink-3
                  transition-colors hover:bg-ink-8 hover:text-ink">
                    Annuler
                </a>
                <button type="submit"
                        class="rounded-btn flex items-center gap-2 bg-brand px-5 py-2.5 text-sm
                       font-bold text-white shadow-sm transition-colors hover:bg-brand-dim">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Publier le deal
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const priceOriginal   = document.getElementById("priceOriginal");
        const priceFinal      = document.getElementById("priceFinal");
        const discountBadge   = document.getElementById("discountBadge");
        const discountText    = document.getElementById("discountText");

        function updateDiscount() {
          const orig  = parseFloat(priceOriginal.value);
          const final = parseFloat(priceFinal.value);
          if (orig > 0 && final >= 0 && final < orig) {
            const pct = Math.round((orig - final) / orig * 100);
            discountText.textContent = `-${pct}% d'économie — vous économisez ${(orig - final).toFixed(2)} €`;
            discountBadge.classList.remove("hidden");
            discountBadge.classList.add("flex");
          } else {
            discountBadge.classList.add("hidden");
            discountBadge.classList.remove("flex");
          }
        }
        priceOriginal.addEventListener("input", updateDiscount);
        priceFinal.addEventListener("input", updateDiscount);
    </script>
}
