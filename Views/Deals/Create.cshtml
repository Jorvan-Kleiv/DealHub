@model DealHub.Models.Deal
@{
    ViewData["Title"] = "Publier un deal";
    Layout = "_Layout";
}

<div class="min-h-screen bg-canvas px-4 py-10">
    <div class="mx-auto mb-8 max-w-2xl">
        <a asp-action="Index"
           class="group mb-5 inline-flex items-center gap-1.5 text-xs text-ink-4 transition-colors hover:text-ink">
            <svg class="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5"
                 fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 3L5 8l5 5" />
            </svg>
            Retour à la liste
        </a>

        <div class="flex items-center gap-3">
            <span class="rounded-card shadow-card flex h-9 w-9 items-center justify-center bg-brand text-white">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
                </svg>
            </span>
            <div>
                <h1 class="font-syne text-xl leading-none font-extrabold text-ink">Publier un deal</h1>
                <p class="mt-0.5 text-xs text-ink-5">Renseignez les informations du bon plan</p>
            </div>
        </div>
    </div>
    <div class="mx-auto max-w-2xl">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly"
                 class="rounded-card mb-5 hidden items-start gap-2 border border-red-200 bg-red-50 px-4 py-3 text-xs text-red-700 [&:not(:empty)]:flex">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" />
                    <path d="M12 8v4m0 4h.01" />
                </svg>
                <span></span>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Informations principales
                </p>
                <div class="mb-4">
                    <label asp-for="Title"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Titre
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <input asp-for="Title"
                           placeholder="Ex : AirPods Pro 2 à -40%…"
                           class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink transition-all
                        placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    <span asp-validation-for="Title" class="mt-1 flex items-center gap-1 text-xs text-red-500"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="Description"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Description
                    </label>
                    <textarea asp-for="Description"
                              rows="3"
                              placeholder="Décrivez le deal, les conditions, la date de fin…"
                              class="rounded-btn w-full resize-none border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink
                           transition-all placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none"></textarea>
                    <span asp-validation-for="Description" class="mt-1 text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="Status"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Statut
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="Status"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                    <span asp-validation-for="Status" class="mt-1 text-xs text-red-500"></span>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Liens &amp; médias
                </p>
                <div class="mb-4">
                    <label asp-for="Url"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        URL du deal
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute top-1/2 left-3 -translate-y-1/2 text-ink-4">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101" />
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M14.828 14.828a4 4 0 015.656 0l-4-4a4 4 0 00-5.656 5.656l-1.1 1.1" />
                            </svg>
                        </span>
                        <input asp-for="Url"
                               type="url"
                               placeholder="https://…"
                               class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-9 text-sm text-ink transition-all
                          placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    </div>
                    <span asp-validation-for="Url" class="mt-1 text-xs text-red-500"></span>
                </div>
                <div>
                    <label asp-for="ImageUrl"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        URL de l'image
                    </label>
                    <div class="relative">
                        <span class="absolute top-1/2 left-3 -translate-y-1/2 text-ink-4">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <rect x="3" y="3" width="18" height="18" rx="2" />
                                <path d="m3 15 5-5 4 4 3-3 4 4" />
                                <circle cx="8.5" cy="8.5" r="1.5" />
                            </svg>
                        </span>
                        <input asp-for="ImageUrl"
                               type="url"
                               placeholder="https://…"
                               id="imageUrlInput"
                               class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-9 text-sm text-ink transition-all
                          placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    </div>
                    <div id="imgPreview"
                         class="rounded-card relative mt-2 hidden h-28 overflow-hidden border border-ink-7 bg-ink-8">
                        <img id="imgPreviewSrc" src="" alt="Aperçu" class="h-full w-full object-cover" />
                    </div>
                    <span asp-validation-for="ImageUrl" class="mt-1 text-xs text-red-500"></span>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-4 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Prix
                </p>

                <div class="mb-4 grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="OriginalPrice"
                               class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix original
                            <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute top-1/2 left-3 -translate-y-1/2 text-sm font-semibold text-ink-4">€</span>
                            <input asp-for="OriginalPrice"
                                   type="number" min="0" step="0.01"
                                   placeholder="0.00"
                                   id="priceOriginal"
                                   class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-7 text-sm text-ink transition-all
                            placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                        </div>
                        <span asp-validation-for="OriginalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="FinalPrice"
                               class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix deal
                            <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="relative">
                            <span class="absolute top-1/2 left-3 -translate-y-1/2 text-sm font-semibold text-ink-4">€</span>
                            <input asp-for="FinalPrice"
                                   type="number" min="0" step="0.01"
                                   placeholder="0.00"
                                   id="priceFinal"
                                   class="rounded-btn w-full border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-7 text-sm text-ink transition-all
                            placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                        </div>
                        <span asp-validation-for="FinalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                </div>
                <div id="discountBadge"
                     class="rounded-badge hidden w-fit items-center gap-2 border border-brand/20 bg-brand/8 px-3 py-2">
                    <svg class="h-3.5 w-3.5 text-brand" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M7 7h.01M7 3h5.586a1 1 0 01.707.293L17 7l-4 4" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9 9 9-9" />
                    </svg>
                    <span id="discountText" class="text-xs font-bold text-brand"></span>
                </div>
            </div>
            <div class="rounded-card shadow-card mb-6 border border-ink-7 bg-surface p-6">
                <p class="font-syne mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Classification
                </p>

                <div class="mb-4">
                    <label asp-for="VoteScore"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Score initial
                    </label>
                    <input asp-for="VoteScore"
                           type="number"
                           placeholder="0"
                           class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink transition-all
                        placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    <span asp-validation-for="VoteScore" class="mt-1 text-xs text-red-500"></span>
                </div>

                {{!-- Utilisateur --}}
                <div class="mb-4">
                    <label asp-for="UserId"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Auteur
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="UserId"
                                asp-items="ViewBag.UserId"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>

                {{!-- Catégorie --}}
                <div class="mb-4">
                    <label asp-for="CategoryId"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Catégorie
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="CategoryId"
                                asp-items="ViewBag.CategoryId"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>

                {{!-- Marchand --}}
                <div>
                    <label asp-for="MerchantId"
                           class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Marchand
                        <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="MerchantId"
                                asp-items="ViewBag.MerchantId"
                                class="rounded-btn w-full cursor-pointer appearance-none border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm
                           text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>
            </div>

            {{!-- ── Actions ───────────────────────────────────────────────── --}}
            <div class="flex items-center justify-between gap-3">
                <a asp-action="Index"
                   class="rounded-btn border border-ink-7 px-4 py-2.5 text-sm font-semibold text-ink-3
                  transition-colors hover:bg-ink-8 hover:text-ink">
                    Annuler
                </a>
                <button type="submit"
                        class="rounded-btn flex items-center gap-2 bg-brand px-5 py-2.5 text-sm
                       font-bold text-white shadow-sm transition-colors hover:bg-brand-dim">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Publier le deal
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const imgInput   = document.getElementById("imageUrlInput");
        const imgPreview = document.getElementById("imgPreview");
        const imgSrc     = document.getElementById("imgPreviewSrc");

        function updatePreview() {
          const url = imgInput.value.trim();
          if (url) {
            imgSrc.src = url;
            imgPreview.classList.remove("hidden");
            imgPreview.classList.add("flex");
          } else {
            imgPreview.classList.add("hidden");
            imgPreview.classList.remove("flex");
          }
        }
        imgInput.addEventListener("input", updatePreview);
        updatePreview();

        // ── Calcul réduction ─────────────────────────────────────────────────
        const priceOriginal   = document.getElementById("priceOriginal");
        const priceFinal      = document.getElementById("priceFinal");
        const discountBadge   = document.getElementById("discountBadge");
        const discountText    = document.getElementById("discountText");

        function updateDiscount() {
          const orig  = parseFloat(priceOriginal.value);
          const final = parseFloat(priceFinal.value);
          if (orig > 0 && final >= 0 && final < orig) {
            const pct = Math.round((orig - final) / orig * 100);
            discountText.textContent = `-${pct}% d'économie — vous économisez ${(orig - final).toFixed(2)} €`;
            discountBadge.classList.remove("hidden");
            discountBadge.classList.add("flex");
          } else {
            discountBadge.classList.add("hidden");
            discountBadge.classList.remove("flex");
          }
        }
        priceOriginal.addEventListener("input", updateDiscount);
        priceFinal.addEventListener("input", updateDiscount);
    </script>
}
