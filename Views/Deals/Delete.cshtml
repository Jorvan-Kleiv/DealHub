@model DealHub.Models.Deal
@{
    ViewData["Title"] = "Supprimer le deal";
    Layout = "_Layout";
}

<div class="mx-auto max-w-2xl py-8">

    <!-- Back -->
    <a asp-action="Index"
       class="group mb-5 inline-flex items-center gap-1.5 text-xs text-ink-4 transition-colors hover:text-ink">
        <svg class="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5"
             fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 3L5 8l5 5" />
        </svg>
        Retour à la liste
    </a>

    <!-- Warning -->
    <div class="mb-6 flex items-start gap-3 rounded-xl border border-red-200 bg-red-50 px-5 py-4">
        <iconify-icon icon="solar:danger-triangle-bold" class="mt-0.5 shrink-0 text-xl text-red-500"></iconify-icon>
        <div>
            <p class="text-sm font-semibold text-red-700">Confirmer la suppression</p>
            <p class="mt-0.5 text-xs text-red-500">Cette action est irréversible. Le deal sera définitivement supprimé.</p>
        </div>
    </div>

    <!-- Deal preview card -->
    <div class="mb-6 overflow-hidden rounded-xl border border-ink-7 bg-surface shadow-sm">

        <!-- Image -->
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="relative aspect-video w-full overflow-hidden">
                <img src="@Model.ImageUrl" alt="@Model.Title"
                     class="h-full w-full object-cover opacity-80" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 to-transparent"></div>
            </div>
        }

        <div class="p-6">

            <!-- Titre + description -->
            <h2 class="font-display text-lg leading-snug font-semibold text-ink">@Model.Title</h2>

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <p class="mt-1 mb-5 line-clamp-2 text-xs leading-relaxed text-ink-4">@Model.Description</p>
            }

            <div class="mb-5 h-px bg-ink-7"></div>

            <!-- Grid infos -->
            <div class="grid grid-cols-2 gap-3">

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Prix deal</p>
                    <p class="font-display text-lg font-bold text-brand">
                        @Model.FinalPrice.ToString("N0")
                        <span class="text-xs font-medium text-ink-4">FCFA</span>
                    </p>
                </div>

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Prix original</p>
                    <p class="font-display text-lg font-bold text-ink-4 line-through">
                        @Model.OriginalPrice.ToString("N0")
                        <span class="text-xs font-medium">FCFA</span>
                    </p>
                </div>

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Catégorie</p>
                    <p class="text-xs font-semibold text-ink-2">@(Model.Category?.Name ?? "—")</p>
                </div>

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Marchand</p>
                    <p class="text-xs font-semibold text-ink-2">@(Model.Merchant?.Name ?? "—")</p>
                </div>

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Score votes</p>
                    <div class="flex items-center gap-1">
                        <iconify-icon icon="solar:fire-linear" class="text-brand"></iconify-icon>
                        <p class="text-xs font-semibold text-ink-2">@(Model.VoteScore ?? 0)</p>
                    </div>
                </div>

                <div class="rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <p class="mb-1 font-semibold tracking-wider text-[10px] text-ink-5 uppercase">Publié par</p>
                    <div class="flex items-center gap-1.5">
                        <div class="flex h-5 w-5 items-center justify-center rounded-full bg-ink-2 font-bold text-[9px] text-white uppercase">
                            @Model.User?.FirstName?.Substring(0, 1)@Model.User?.LastName?.Substring(0, 1)
                        </div>
                        <p class="text-xs font-semibold text-ink-2">
                            @Model.User?.FirstName @Model.User?.LastName?.Substring(0, 1).
                        </p>
                    </div>
                </div>

            </div>

            <!-- URL -->
            @if (!string.IsNullOrEmpty(Model.Url))
            {
                <div class="mt-3 flex items-center gap-2 rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5">
                    <iconify-icon icon="solar:link-linear" class="shrink-0 text-ink-5"></iconify-icon>
                    <a href="@Model.Url" target="_blank"
                       class="truncate text-xs text-brand underline-offset-2 hover:underline">
                        @Model.Url
                    </a>
                </div>
            }

        </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between gap-3">
        <a asp-action="Index"
           class="rounded-lg border border-ink-7 px-4 py-2.5 text-sm font-semibold text-ink-3 transition-colors hover:bg-ink-8 hover:text-ink">
            Annuler
        </a>
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <button type="submit"
                    class="flex items-center gap-2 rounded-lg bg-red-600 px-5 py-2.5 text-sm font-bold text-white shadow-sm transition-all hover:bg-red-700 active:scale-95">
                <iconify-icon icon="solar:trash-bin-bold"></iconify-icon>
                Supprimer définitivement
            </button>
        </form>
    </div>

</div>
