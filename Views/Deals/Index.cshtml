@model DealDto

@{
    ViewData["Title"] = "Deal's list";
}
@section nav {
    <nav class="sticky top-16 z-40 border-b border-gray-200 bg-white">
        <div class="mx-auto flex max-w-[1440px] items-center gap-4 px-4 py-2 lg:px-6">

            <div class="flex items-center gap-2 border-r border-gray-200 pr-4">
                <button class="flex items-center gap-1.5 rounded-full bg-stone-800 px-3 py-1.5 text-xs font-medium tracking-wide text-white">
                    <iconify-icon icon="solar:fire-linear" class="text-sm"></iconify-icon>
                    Trending
                </button>
                <button class="flex items-center gap-1.5 rounded-full bg-transparent px-3 py-1.5 text-xs font-medium tracking-wide text-mutated transition-colors hover:bg-background hover:text-stone-800">
                    <iconify-icon icon="solar:clock-circle-linear" class="text-sm"></iconify-icon>
                    Récents
                </button>
            </div>

            <div class="no-scrollbar flex flex-1 items-center gap-2 overflow-x-auto">
                @foreach (var category in Model.Categories)
                {
                    <a asp-controller="Category" asp-action="DisplayByCategory" class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium whitespace-nowrap text-mutated transition-colors hover:border-stone-800 hover:text-stone-800">@category.Name</a>
                }
            </div>

            <div class="hidden items-center border-l border-gray-200 pl-4 lg:flex">
                <div class="group relative flex cursor-pointer items-center gap-2 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-stone-800 transition-colors hover:bg-background">
                    <iconify-icon icon="solar:sort-from-top-to-bottom-linear"></iconify-icon>
                    Trier par
                    <iconify-icon icon="solar:alt-arrow-down-linear" class="text-mutated"></iconify-icon>
                </div>
            </div>

        </div>
    </nav>
}
<h2 class="font-display text-3xl font-semibold text-stone-700">Les deals du moment</h2>
<div class="flex min-h-screen flex-col gap-8 py-6 selection:bg-brand/10 selection:text-brand">
    <div class="grid min-h-screen grid-cols-4 gap-4">
        <div class="col-span-3 grid min-h-full grid-cols-3 gap-4">
            @foreach (var deal in Model.Deals)
            {
                <a asp-controller="Deals" asp-action="Details" asp-route-id="@deal.Id" class="group flex h-full w-full cursor-pointer flex-col rounded-md bg-white outline-brand/60 transition-colors duration-500 hover:outline">
                    <div class="aspect-video w-full overflow-hidden rounded-t-md">
                        <img src="@(deal.ImageUrl)" alt="@(deal.ImageUrl)" class="aspect-video w-full rounded-t-md object-cover transition-all duration-500 group-hover:scale-110 group-hover:rounded-t-md" />
                    </div>
                    <div class="flex flex-col justify-between gap-1.5 px-4 py-1.5">
                        <div class="flex items-center gap-2">
                            <span class="rounded-sm bg-brand/15 px-1.5 py-0.5 font-semibold text-[10px] text-brand uppercase">@deal.Category?.Name</span>
                            <p class="text-[10px] text-ink-5">• @(deal.Merchant?.Name ?? "Inconnu")</p>
                        </div>
                        <div class="flex flex-col gap-2 font-sans">
                            <h4 class="line-clamp-1 text-base leading-tight font-semibold text-ink-2 decoration-brand/80 underline-offset-2 transition-all duration-500 group-hover:text-brand group-hover:underline">@deal.Title</h4>
                            <p class="line-clamp-2 text-xs leading-tight text-ink-4">@deal.Description</p>
                        </div>
                        <div class="mt-2 flex items-center gap-2 rounded-md">
                            <h3 class="fle text-xl leading-none font-semibold tracking-tighter text-brand">@deal.FinalPrice FCFA</h3>
                            <span class="decoration-red text-xs leading-none tracking-tighter text-gray-400 line-through">@deal.OriginalPrice FCFA</span>
                        </div>
                        <div class="flex w-full flex-col gap-2">
                            <div class="min-h-0.5 min-w-full bg-gray-300"></div>
                            <div class="flex w-full items-center justify-between bg-blue-300">
                                <div class="flex w-1/3 items-center gap-1">
                                    <div class="flex h-6 w-6 items-center justify-center rounded-full border border-gray-300 bg-gray-200 font-medium text-[10px] text-gray-400 uppercase">
                                        @deal.User?.FirstName.Substring(0, 1)
                                    </div>
                                    <p class="font-medium text-gray-400 text-[10px]">@deal.User?.FirstName</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </a>
            }
        </div>
        <div class="col-span-1 grid h-full min-h-full grid-cols-3 bg-brand/10 text-stone-700">Misere</div>
    </div>

</div>

