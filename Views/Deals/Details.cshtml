@model DealHub.Models.Deal

@{
    ViewData["Title"] = Model.Title.Replace(" ", "-");
}

<div class="flex min-h-screen flex-col gap-8 py-6 selection:bg-brand/10 selection:text-brand">
    <div class="grid grid-cols-4 gap-6">
        <div class="col-span-3 flex flex-col gap-6">
            <div class="relative w-full overflow-hidden rounded-xl">
                <img src="@(Model.ImageUrl ?? "/images/placeholder.jpg")"
                     alt="@Model.Title"
                     class="aspect-video w-full object-cover" />
            </div>
            <div class="flex flex-col gap-3">
                <div class="flex items-center gap-2 text-[10px] text-ink-4">
                    <span>@Model.Merchant?.Name</span>
                    <span class="h-1 w-1 rounded-full bg-ink-5"></span>
                    <span>@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                    <span class="h-1 w-1 rounded-full bg-ink-5"></span>
                    <div class="flex items-center gap-1">
                        <div class="flex h-4 w-4 items-center justify-center rounded-full bg-ink-2 font-bold text-[8px] text-ink-6 uppercase">
                            @Model.User?.FirstName?.Substring(0, 1)
                        </div>
                        <span>@Model.User?.FirstName @Model.User?.LastName?.Substring(0, 1).</span>
                    </div>
                </div>
                <h1 class="font-display text-2xl leading-snug font-semibold text-ink-2">
                    @Model.Title
                </h1>
            </div>

            <div class="flex items-center gap-4 rounded-xl border border-ink-7 bg-white px-5 py-4">
                <div class="flex flex-col gap-0.5">
                    <span class="font-medium tracking-wider text-[10px] text-ink-4 uppercase">Prix deal</span>
                    <div class="flex items-baseline gap-1.5">
                        <span class="font-display text-3xl font-bold tracking-tight text-brand">
                            @Model.FinalPrice
                        </span>
                        <span class="rounded-sm bg-blue-100 px-1 py-0.5 font-bold text-[10px] text-blue-500 uppercase">fcfa</span>
                    </div>
                </div>
                <div class="h-10 w-px bg-ink-6"></div>
                <div class="flex flex-col gap-0.5">
                    <span class="font-medium tracking-wider text-[10px] text-ink-4 uppercase">Prix original</span>
                    <span class="font-display text-xl font-semibold tracking-tight text-ink-5 line-through">
                        @Model.OriginalPrice FCFA
                    </span>
                </div>
                <div class="h-10 w-px bg-ink-6"></div>

                @{
                    var saving = Model.OriginalPrice - Model.FinalPrice;
                    var pct = Model.OriginalPrice > 0
                    ? (int)Math.Round((double)saving / Model.OriginalPrice * 100)
                    : 0;
                }
                <div class="flex flex-col gap-0.5">
                    <span class="font-medium tracking-wider text-[10px] text-ink-4 uppercase">Économie</span>
                    <div class="flex items-baseline gap-1.5">
                        <span class="font-display text-xl font-bold text-green-600">-@pct%</span>
                        <span class="text-xs text-ink-4">(@saving FCFA)</span>
                    </div>
                </div> 

                <a href="@Model.Url" target="_blank"
                   class="ml-auto flex items-center gap-2 rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-white shadow-[0_2px_10px_rgba(255,69,0,.3)] transition hover:bg-brand-dim active:scale-95">
                    Voir le deal
                    <iconify-icon icon="solar:arrow-right-up-linear"></iconify-icon>
                </a>
            </div>

            <div class="flex flex-col gap-3 rounded-xl border border-ink-7 bg-white px-5 py-4">
                <h3 class="font-display text-sm font-semibold text-ink-2">Description</h3>
                <div class="h-px bg-ink-7"></div>
                <p class="text-sm leading-relaxed text-ink-4">@Model.Description</p>
            </div>

            <div class="flex flex-col gap-4 rounded-xl border border-ink-7 bg-white px-5 py-4">

                <div class="flex items-center justify-between">
                    <h3 class="font-display text-sm font-semibold text-ink-2">
                        Commentaires <span class="ml-1 rounded-full bg-ink-7 px-2 py-0.5 font-bold text-[10px] text-ink-4">3</span>
                    </h3>
                </div>
                <div class="h-px bg-ink-7"></div>

                <div class="flex items-start gap-3">
                    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand/15 text-xs font-bold text-brand uppercase">
                        @Model.User?.FirstName?.Substring(0, 1)
                    </div>
                    <div class="flex flex-1 flex-col gap-2">
                        <textarea rows="2"
                                  placeholder="Ajouter un commentaire…"
                                  class="w-full resize-none rounded-lg border border-ink-7 bg-ink-9 px-3 py-2 text-xs text-ink-2 placeholder-ink-5 transition outline-none focus:border-brand focus:ring-2 focus:ring-brand/10"></textarea>
                        <div class="flex justify-end">
                            <button class="flex items-center gap-1.5 rounded-lg bg-brand px-4 py-1.5 text-xs font-semibold text-white transition hover:bg-brand-dim active:scale-95">
                                <iconify-icon icon="solar:send-linear"></iconify-icon>
                                Commenter
                            </button>
                        </div>
                    </div>
                </div>

                <div class="h-px bg-ink-7"></div>

                <div class="flex flex-col gap-4">

                    @foreach (var comment in new[] {
                                        new { Initials="AD", Name="Alice D.",   Time="il y a 2h",  Text="Super deal ! Je viens de commander, livraison rapide confirmée 👌",         Likes=4 },
                                        new { Initials="BM", Name="Bob M.",     Time="il y a 5h",  Text="Attention, le prix a légèrement remonté sur Amazon. Toujours intéressant.",  Likes=2 },
                                        new { Initials="CK", Name="Clara K.",   Time="hier",       Text="Meilleur prix que j'ai vu depuis 6 mois, code promo DEAL10 en plus !",       Likes=7 },
                                        })
                    {
                        <div class="flex items-start gap-3">
                            <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-ink-7 bg-ink-2 font-bold text-[10px] text-ink-5 uppercase">
                                @comment.Initials
                            </div>
                            <div class="flex flex-1 flex-col gap-1.5">
                                <div class="flex items-center gap-2">
                                    <span class="text-xs font-semibold text-ink-2">@comment.Name</span>
                                    <span class="text-[10px] text-ink-5">@comment.Time</span>
                                </div>
                                <div class="rounded-lg rounded-tl-none border border-ink-7 bg-ink-9 px-3 py-2 text-xs leading-relaxed text-ink-3">
                                    @comment.Text
                                </div>
                                <div class="flex items-center gap-3">
                                    <button class="flex items-center gap-1 font-medium text-[10px] text-ink-4 transition hover:text-brand">
                                        <iconify-icon icon="solar:like-linear" class="text-sm"></iconify-icon>
                                        @comment.Likes
                                    </button>
                                    <button class="font-medium text-[10px] text-ink-4 transition hover:text-ink-2">
                                        Répondre
                                    </button>
                                </div>
                            </div>
                        </div>
                    }

                </div>
            </div>

        </div>
        <div class="col-span-1">
            <div class="sticky top-28 flex flex-col gap-3">

                <div class="rounded-xl border border-ink-7 bg-white px-5 py-4">
                    <h3 class="font-display mb-3 text-sm font-semibold text-ink-2">Infos du deal</h3>
                    <div class="mb-3 h-px bg-ink-7"></div>

                    <div class="flex flex-col gap-3">

                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Statut</span>
                            <span class="rounded-full px-2.5 py-0.5 text-xs font-semibold capitalize">
                                @Model.Status
                            </span>
                        </div>

                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Catégorie</span>
                            <span class="rounded-sm border border-brand/85 bg-brand/15 px-2 py-0.5 font-bold text-[10px] text-brand uppercase">
                                @Model.Category?.Name
                            </span>
                        </div>

                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Marchand</span>
                            <span class="text-xs font-semibold text-ink-2">
                                @(Model.Merchant?.Name ?? "—")
                            </span>
                        </div>

                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Publié le</span>
                            <span class="text-xs font-semibold text-ink-2">
                                @Model.CreatedAt.ToString("dd MMM yyyy")
                            </span>
                        </div>

                        <div class="h-px bg-ink-7"></div>
                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Publié par</span>
                            <div class="flex items-center gap-2">
                                <div class="flex h-6 w-6 items-center justify-center rounded-full border border-ink-7 bg-ink-2 font-bold text-[10px] text-ink-5 uppercase">
                                    @Model.User?.FirstName?.Substring(0, 1)@Model.User?.LastName?.Substring(0, 1)
                                </div>
                                <span class="text-xs font-semibold text-ink-2">
                                    @Model.User?.FirstName <span class="text-ink-4">@Model.User?.LastName?.Substring(0, 1).</span>
                                </span>
                            </div>
                        </div>
                        <div class="flex items-center justify-between">
                            <span class="text-xs text-ink-4">Score</span>
                            <div class="flex items-center gap-1">
                                <iconify-icon icon="solar:fire-linear" class="text-sm text-brand"></iconify-icon>
                                <span class="text-xs font-bold text-ink-2">@(Model.VoteScore ?? 0) votes</span>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="rounded-xl border border-ink-7 bg-white px-5 py-4">
                    <h3 class="font-display mb-3 text-sm font-semibold text-ink-2">Actions</h3>
                    <div class="mb-3 h-px bg-ink-7"></div>
                    <div class="flex flex-col gap-2">
                        <a href="@Model.Url" target="_blank"
                           class="flex items-center justify-center gap-2 rounded-lg bg-brand px-4 py-2.5 text-xs font-semibold text-white shadow-[0_2px_10px_rgba(255,69,0,.3)] transition hover:bg-brand-dim active:scale-95">
                            <iconify-icon icon="solar:arrow-right-up-linear"></iconify-icon>
                            Voir le deal
                        </a>
                        <a asp-controller="Deals" asp-action="Edit" asp-route-id="@Model.Id"
                           class="flex items-center justify-center gap-2 rounded-lg border border-ink-7 bg-white px-4 py-2.5 text-xs font-semibold text-ink-3 transition hover:border-ink-4 hover:text-ink-2">
                            <iconify-icon icon="solar:pen-linear"></iconify-icon>
                            Modifier
                        </a>
                        <a asp-controller="Deals" asp-action="Delete" asp-route-id="@Model.Id"
                           class="flex items-center justify-center gap-2 rounded-lg border border-red-200 bg-red-50 px-4 py-2.5 text-xs font-semibold text-red-500 transition hover:bg-red-100 active:scale-95">
                            <iconify-icon icon="solar:trash-bin-linear"></iconify-icon>
                            Supprimer
                        </a>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>
