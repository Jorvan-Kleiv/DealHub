@model DealHub.Models.DealRequest
@{
    ViewData["Title"] = "Modifier un deal";
    Layout = "_Layout";
}

<div class="flex min-h-screen flex-col items-end gap-6 bg-canvas px-4">
    <div class="mx-auto flex w-4xl max-w-4xl flex-col self-start sm:w-full">
        <a asp-action="Index"
           class="group mb-5 inline-flex items-center gap-1.5 text-xs text-ink-4 transition-colors hover:text-ink">
            <svg class="h-3.5 w-3.5 transition-transform group-hover:-translate-x-0.5"
                 fill="none" viewBox="0 0 16 16" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 3L5 8l5 5" />
            </svg>
            Retour à la liste
        </a>

        <div class="flex items-center gap-3">
            <span class="flex h-9 w-9 items-center justify-center rounded-xl bg-ink-2 text-white shadow-sm">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
            </span>
            <div>
                <h1 class="font-display text-xl leading-none font-semibold text-ink">Modifier le deal</h1>
                <p class="mt-0.5 line-clamp-1 text-xs text-ink-5">@Model.Deal.Title</p>
            </div>
        </div>
    </div>

    <div class="mx-auto w-4xl max-w-4xl sm:w-full">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Deal.Id" />

            <div asp-validation-summary="ModelOnly"
                 class="mb-5 hidden items-start gap-2 rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-xs text-red-700 [&:not(:empty)]:flex">
                <svg class="mt-0.5 h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10" /><path d="M12 8v4m0 4h.01" />
                </svg>
                <span></span>
            </div>

            <div class="mb-4 rounded-xl border border-ink-7 bg-surface p-6 shadow-sm">
                <p class="font-display mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Informations principales
                </p>

                <div class="mb-4">
                    <label asp-for="Deal.Title" class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Titre <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <input asp-for="Deal.Title" placeholder="Ex : AirPods Pro 2 à -40%…"
                           class="w-full rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink transition-all placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    <span asp-validation-for="Deal.Title" class="mt-1 flex items-center gap-1 text-xs text-red-500"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Deal.Description" class="mb-1.5 block text-xs font-semibold text-ink-3">Description</label>
                    <textarea asp-for="Deal.Description" rows="3"
                              placeholder="Décrivez le deal, les conditions, la date de fin…"
                              class="w-full resize-none rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5 text-sm text-ink transition-all placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none"></textarea>
                    <span asp-validation-for="Deal.Description" class="mt-1 text-xs text-red-500"></span>
                </div>

                <div>
                    <label class="mb-2 block text-xs font-semibold text-ink-3">
                        Statut <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="grid grid-cols-4 gap-2" id="statusGroup">
                        @foreach (var s in new[] {
                            new { Value="ACTIVE",   Label="Actif",    Icon="solar:check-circle-linear",
                                  ActiveCls="border-green-400 bg-green-50 text-green-700",
                                  IdleCls="border-ink-7 bg-ink-9 text-ink-4 hover:border-ink-5" },
                            new { Value="EXPIRED",  Label="Expiré",   Icon="solar:close-circle-linear",
                                  ActiveCls="border-red-400 bg-red-50 text-red-600",
                                  IdleCls="border-ink-7 bg-ink-9 text-ink-4 hover:border-ink-5" },
                            new { Value="REPORTED", Label="Signalé",  Icon="solar:danger-triangle-linear",
                                  ActiveCls="border-amber-400 bg-amber-50 text-amber-600",
                                  IdleCls="border-ink-7 bg-ink-9 text-ink-4 hover:border-ink-5" },
                            new { Value="DELETED",  Label="Supprimé", Icon="solar:trash-bin-linear",
                                  ActiveCls="border-stone-400 bg-stone-100 text-stone-600",
                                  IdleCls="border-ink-7 bg-ink-9 text-ink-4 hover:border-ink-5" },
                        })
                        {
                            var isSelected = Model.Deal.Status.ToString() == s.Value;
                            <label data-status-pill
                                   data-value="@s.Value"
                                   data-active="@s.ActiveCls"
                                   data-idle="@s.IdleCls"
                                   class="flex cursor-pointer items-center gap-2 rounded-lg border px-3 py-2.5 text-xs font-semibold transition-all duration-150 select-none @(isSelected ? s.ActiveCls : s.IdleCls)">
                                <input type="radio" asp-for="Deal.Status" value="@s.Value" class="sr-only"
                                       checked="@(isSelected ? "checked" : null)" />
                                <iconify-icon icon="@s.Icon" class="pointer-events-none text-base"></iconify-icon>
                                @s.Label
                            </label>
                        }
                    </div>
                    <span asp-validation-for="Deal.Status" class="mt-1 text-xs text-red-500"></span>
                </div>
            </div>

            
            <div class="mb-4 rounded-xl border border-ink-7 bg-surface p-6 shadow-sm">
                <p class="font-display mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Liens &amp; médias
                </p>

                <div class="mb-4">
                    <label asp-for="Deal.Url" class="mb-1.5 block text-xs font-semibold text-ink-3">
                        URL du deal
                    </label>
                    <div class="relative">
                        <span class="absolute top-1/2 left-3 -translate-y-1/2 text-ink-4">
                            <iconify-icon icon="solar:link-linear" class="text-base"></iconify-icon>
                        </span>
                        <input asp-for="Deal.Url" type="url" placeholder="https://…"
                               class="w-full rounded-lg border border-ink-7 bg-ink-9 py-2.5 pr-3 pl-9 text-sm text-ink transition-all placeholder:text-ink-5 focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none" />
                    </div>
                    <span asp-validation-for="Deal.Url" class="mt-1 text-xs text-red-500"></span>
                </div>

               
                <div>
                    <label class="mb-1.5 block text-xs font-semibold text-ink-3">Image du deal</label>

                    <div id="existingImgWrap"
                         class="@(string.IsNullOrEmpty(Model.Deal.ImageUrl) ? "hidden" : "") overflow-hidden rounded-xl border border-ink-7">
                        <div class="relative aspect-video w-full overflow-hidden bg-ink-8">
                            <img id="existingImgEl" src="@Model.Deal.ImageUrl" alt="Image actuelle"
                                 class="h-full w-full object-cover" />
                            {{-- overlay bouton remplacer --}}
                            <div class="absolute inset-0 flex items-center justify-center bg-black/0 transition-all duration-200 hover:bg-black/30"
                                 id="imgOverlay">
                                <button type="button" id="btnReplace"
                                        class="scale-90 rounded-full border border-white/80 bg-white/90 px-4 py-2 text-xs font-bold text-ink opacity-0 shadow-md backdrop-blur-sm transition-all duration-200 hover:bg-white"
                                        onclick="triggerReplace()">
                                    <iconify-icon icon="solar:upload-linear" class="mr-1 text-sm"></iconify-icon>
                                    Remplacer l'image
                                </button>
                            </div>
                        </div>
                        <div class="flex items-center justify-between border-t border-ink-7 bg-ink-9 px-3 py-1.5">
                            <span class="flex items-center gap-1.5 text-[10px] text-ink-5">
                                <iconify-icon icon="solar:gallery-linear" class="text-xs"></iconify-icon>
                                Image actuelle
                            </span>
                            <button type="button" onclick="triggerReplace()"
                                    class="font-semibold text-[10px] text-brand transition hover:underline">
                                Remplacer →
                            </button>
                        </div>
                    </div>

                    <div id="uploadZoneWrap" class="@(!string.IsNullOrEmpty(Model.Deal.ImageUrl) ? "hidden" : "")">

                        <label for="imageFile" id="uploadZone"
                               class="relative flex h-36 w-full cursor-pointer flex-col items-center justify-center gap-2 overflow-hidden rounded-xl border-2 border-dashed border-ink-6 bg-ink-9 transition-all hover:border-brand hover:bg-brand/[.04]">
                            <div id="uploadPlaceholder" class="pointer-events-none flex flex-col items-center gap-1.5 text-ink-4">
                                <iconify-icon icon="solar:upload-linear" style="font-size:28px;"></iconify-icon>
                                <span class="text-xs font-medium">Cliquez ou glissez une image</span>
                                <small class="text-[10px] text-ink-5">PNG, JPG, WEBP — max 5 Mo</small>
                            </div>
                            <img id="imgPreview"
                                 class="absolute inset-0 hidden h-full w-full rounded-[10px] object-cover"
                                 src="" alt="Aperçu" />
                        </label>

                        <div id="fileInfo"
                             class="mt-2 hidden items-center justify-between gap-2 rounded-lg border border-ink-7 bg-ink-8 px-2.5 py-1.5">
                            <div class="flex min-w-0 items-center gap-1.5 text-ink-3">
                                <iconify-icon icon="solar:gallery-linear" class="flex-shrink-0 text-brand" style="font-size:14px;"></iconify-icon>
                                <span id="fileName" class="truncate text-xs"></span>
                            </div>
                            <button type="button" id="btnCancelReplace"
                                    class="flex items-center gap-1 rounded px-1.5 py-0.5 font-semibold text-[10px] text-ink-4 transition hover:text-red-500">
                                <iconify-icon icon="solar:close-circle-linear" style="font-size:13px;"></iconify-icon>
                                Annuler
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.Deal.ImageUrl))
                        {
                            <button type="button" id="btnCancelReplaceAlt"
                                    class="mt-2 flex items-center gap-1.5 font-semibold text-[10px] text-ink-4 transition hover:text-ink">
                                <iconify-icon icon="solar:arrow-left-linear" class="text-xs"></iconify-icon>
                                Garder l'image actuelle
                            </button>
                        }
                    </div>

                    <input asp-for="ImageFile" type="file" id="imageFile" name="ImageFile"
                           accept="image/png,image/jpeg,image/webp,image/gif" class="sr-only" />
                </div>
            </div>

   
            <div class="mb-4 rounded-xl border border-ink-7 bg-surface p-6 shadow-sm">
                <p class="font-display mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">Prix</p>
                <div class="mb-4 grid grid-cols-2 gap-4">
                    <div>
                        <label asp-for="Deal.OriginalPrice" class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix original <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="flex w-full items-center rounded-lg border border-ink-7 bg-ink-9 px-3 text-sm text-ink transition-all focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/15">
                            <input asp-for="Deal.OriginalPrice" type="number" min="0" step="0.01"
                                   placeholder="0.00" id="priceOriginal" class="grow bg-transparent py-2.5 focus:outline-none" />
                            <span class="text-sm font-semibold text-ink-4">FCFA</span>
                        </div>
                        <span asp-validation-for="Deal.OriginalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                    <div>
                        <label asp-for="Deal.FinalPrice" class="mb-1.5 block text-xs font-semibold text-ink-3">
                            Prix deal <span class="ml-0.5 text-brand">*</span>
                        </label>
                        <div class="flex w-full items-center rounded-lg border border-ink-7 bg-ink-9 px-3 text-sm text-ink transition-all focus-within:border-brand focus-within:ring-2 focus-within:ring-brand/15">
                            <input asp-for="Deal.FinalPrice" type="number" min="0" step="0.01"
                                   placeholder="0.00" id="priceFinal" class="grow bg-transparent py-2.5 focus:outline-none" />
                            <span class="text-sm font-semibold text-ink-4">FCFA</span>
                        </div>
                        <span asp-validation-for="Deal.FinalPrice" class="mt-1 text-xs text-red-500"></span>
                    </div>
                </div>
                <div id="discountBadge"
                     class="hidden w-fit items-center gap-2 rounded-full border border-brand/20 bg-brand/8 px-3 py-2">
                    <iconify-icon icon="solar:tag-price-linear" class="text-sm text-brand"></iconify-icon>
                    <span id="discountText" class="text-xs font-bold text-brand"></span>
                </div>
            </div>

            <div class="mb-6 rounded-xl border border-ink-7 bg-surface p-6 shadow-sm">
                <p class="font-display mb-5 text-xs font-bold tracking-widest text-ink-4 uppercase">
                    Catégorie &amp; Marchand
                </p>
                <div class="mb-4">
                    <label asp-for="Deal.CategoryId" class="mb-1.5 block text-xs font-semibold text-ink-3">
                        Catégorie <span class="ml-0.5 text-brand">*</span>
                    </label>
                    <div class="relative">
                        <select asp-for="Deal.CategoryId"
                                asp-items="@(new SelectList(Model.Categories, "Id", "Name", Model.Deal.CategoryId))"
                                class="w-full cursor-pointer appearance-none rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>
                <div>
                    <label asp-for="Deal.MerchantId" class="mb-1.5 block text-xs font-semibold text-ink-3">Marchand</label>
                    <div class="relative">
                        <select asp-for="Deal.MerchantId"
                                asp-items="@(new SelectList(Model.Merchants, "Id", "Name", Model.Deal.MerchantId))"
                                class="w-full cursor-pointer appearance-none rounded-lg border border-ink-7 bg-ink-9 px-3 py-2.5 pr-9 text-sm text-ink transition-all focus:border-brand focus:ring-2 focus:ring-brand/15 focus:outline-none">
                            <option value="">— Aucun —</option>
                        </select>
                        <svg class="pointer-events-none absolute top-1/2 right-3 h-4 w-4 -translate-y-1/2 text-ink-4"
                             fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </div>
                </div>
            </div>

            <div class="flex items-center justify-between gap-3">
                <a asp-action="Index"
                   class="rounded-lg border border-ink-7 px-4 py-2.5 text-sm font-semibold text-ink-3 transition-colors hover:bg-ink-8 hover:text-ink">
                    Annuler
                </a>
                <button type="submit"
                        class="flex items-center gap-2 rounded-lg bg-ink-2 px-5 py-2.5 text-sm font-bold text-white shadow-sm transition-colors hover:bg-ink active:scale-95">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Enregistrer les modifications
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const pills = document.querySelectorAll('[data-status-pill]');

        function updatePills() {
            pills.forEach(pill => {
                const radio = pill.querySelector('input[type="radio"]');

                const active = pill.dataset.active.trim().split(/\s+/).filter(Boolean);
                const idle   = pill.dataset.idle.trim().split(/\s+/).filter(Boolean);

               
                pill.classList.remove(...active, ...idle);


                if (radio.checked) {
                    pill.classList.add(...active);
                } else {
                    pill.classList.add(...idle);
                }
            });
        }

        pills.forEach(pill => {
            const radio = pill.querySelector('input[type="radio"]');
            radio.addEventListener('change', updatePills);
        });

        updatePills();


        const priceOriginal = document.getElementById('priceOriginal');
        const priceFinal    = document.getElementById('priceFinal');
        const discountBadge = document.getElementById('discountBadge');
        const discountText  = document.getElementById('discountText');

        function updateDiscount() {
            const orig  = parseFloat(priceOriginal.value);
            const final = parseFloat(priceFinal.value);
            if (orig > 0 && final >= 0 && final < orig) {
                const pct    = Math.round((orig - final) / orig * 100);
                const saving = (orig - final).toLocaleString('fr-FR');
                discountText.textContent = `-${pct}% · vous économisez ${saving} FCFA`;
                discountBadge.classList.remove('hidden');
                discountBadge.classList.add('flex');
            } else {
                discountBadge.classList.add('hidden');
                discountBadge.classList.remove('flex');
            }
        }
        priceOriginal?.addEventListener('input', updateDiscount);
        priceFinal?.addEventListener('input', updateDiscount);
        if(priceOriginal && priceFinal) updateDiscount();


        const imageFile         = document.getElementById('imageFile');
        const imgPreview        = document.getElementById('imgPreview');
        const uploadPlaceholder = document.getElementById('uploadPlaceholder');
        const fileInfo          = document.getElementById('fileInfo');
        const fileNameEl        = document.getElementById('fileName');
        const existingImgWrap   = document.getElementById('existingImgWrap');
        const uploadZoneWrap    = document.getElementById('uploadZoneWrap');
        const btnCancelReplace  = document.getElementById('btnCancelReplace');
        const btnCancelReplaceAlt = document.getElementById('btnCancelReplaceAlt');
        const imgOverlay        = document.getElementById('imgOverlay');
        const btnReplace        = document.getElementById('btnReplace');

        
        if (imgOverlay && btnReplace) {
            imgOverlay.addEventListener('mouseenter', () => {
                btnReplace.style.opacity  = '1';
                btnReplace.style.transform = 'scale(1)';
            });
            imgOverlay.addEventListener('mouseleave', () => {
                btnReplace.style.opacity  = '0';
                btnReplace.style.transform = 'scale(0.9)';
            });
        }

        window.triggerReplace = function() {
            if(existingImgWrap) existingImgWrap.classList.add('hidden');
            if(uploadZoneWrap) uploadZoneWrap.classList.remove('hidden');
            imageFile.click();
        };

        function cancelReplace() {
            imageFile.value = '';
            imgPreview.classList.add('hidden');
            imgPreview.src = '';
            uploadPlaceholder.classList.remove('hidden');

            fileInfo.classList.add('hidden');
            fileInfo.classList.remove('flex');

            const hasExistingImage = existingImgWrap && existingImgWrap.querySelector('img').getAttribute('src');
            if (hasExistingImage) {
                uploadZoneWrap?.classList.add('hidden');
                existingImgWrap?.classList.remove('hidden');
            }
        }

        btnCancelReplace?.addEventListener('click', cancelReplace);
        btnCancelReplaceAlt?.addEventListener('click', cancelReplace);


        imageFile.addEventListener('change', e => {
            const file = e.target.files[0];
            if (!file) return; 

            const url = URL.createObjectURL(file);
            imgPreview.src = url;
            imgPreview.classList.remove('hidden');
            uploadPlaceholder.classList.add('hidden');

            fileNameEl.textContent = file.name;
            fileInfo.classList.remove('hidden');
            fileInfo.classList.add('flex');
        });
    </script>
}
