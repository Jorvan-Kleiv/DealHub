<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealHub — Admin</title>
    <link rel="stylesheet" href="~/css/output.css" />
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>

</head>

<body class="flex h-screen overflow-hidden bg-canvas font-sans text-ink text-[13px]">
    <div id="mob-overlay" onclick="closeMobile()"></div>
    <aside id="sidebar" class="flex shrink-0 flex-col overflow-hidden border-r border-dark-border bg-dark">
        <!-- Logo -->
        <div class="flex h-[52px] shrink-0 items-center gap-2 overflow-hidden border-b border-dark-border px-3">
            <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-brand">
                <iconify-icon icon="solar:tag-bold" class="text-sm text-white"></iconify-icon>
            </div>
            <span class="sb-text font-syne text-sm font-extrabold tracking-tight text-white">DealHub</span>
            <span class="sb-badge rounded border border-brand/20 bg-brand/15 px-1.5 py-0.5 leading-none font-bold text-[9px] text-brand">ADMIN</span>
        </div>

        <!-- Nav -->
        <nav class="flex flex-1 flex-col gap-0.5 overflow-x-hidden overflow-y-auto px-2 py-3" id="sb-nav">
            <p class="sb-section px-2 pt-1 pb-1.5 font-bold tracking-widest text-[9px] text-dark-text/50 uppercase">
                Principal
            </p>

            <a href="/" class="nav-item active" data-tip="Vue d'ensemble">
                <span class="nav-icon">
                    <iconify-icon icon="solar:widget-5-bold-duotone"
                                  class="text-brand"></iconify-icon>
                </span>
                <span class="sb-text">Vue d'ensemble</span>
            </a>
            <a href="/" class="nav-item" data-tip="Utilisateurs">
                <span class="nav-icon"><iconify-icon icon="solar:users-group-rounded-linear"></iconify-icon></span>
                <span class="sb-text">Utilisateurs</span>
                <span class="sb-badge ml-auto rounded bg-white/[.07] px-1.5 py-0.5 font-bold text-[9px] text-dark-text">248</span>
            </a>
            <a href="/" class="nav-item" data-tip="Deals">
                <span class="nav-icon"><iconify-icon icon="solar:tag-linear"></iconify-icon></span>
                <span class="sb-text">Deals</span>
            </a>
            <a href="/" class="nav-item" data-tip="Marchands">
                <span class="nav-icon"><iconify-icon icon="solar:shop-2-linear"></iconify-icon></span>
                <span class="sb-text">Marchands</span>
            </a>
            <a href="/" class="nav-item" data-tip="Modération" onclick="navigate('moderation')">
                <span class="nav-icon"><iconify-icon icon="solar:shield-warning-linear"></iconify-icon></span>
                <span class="sb-text">Modération</span>
                <span class="sb-badge ml-auto h-1.5 w-1.5 shrink-0 rounded-full bg-red-500"></span>
            </a>
            <a href="/" class="nav-item" data-tip="Statistiques" onclick="navigate('stats')">
                <span class="nav-icon"><iconify-icon icon="solar:chart-2-linear"></iconify-icon></span>
                <span class="sb-text">Statistiques</span>
            </a>

            <p class="sb-section px-2 pt-3 pb-1.5 font-bold tracking-widest text-[9px] text-dark-text/50 uppercase">
                Système
            </p>
            <a href="/" class="nav-item" data-tip="Configuration" onclick="navigate('config')">
                <span class="nav-icon"><iconify-icon icon="solar:settings-linear"></iconify-icon></span>
                <span class="sb-text">Configuration</span>
            </a>
        </nav>

        <!-- Footer -->
        <div class="shrink-0 border-t border-dark-border p-2">
            <div class="flex cursor-pointer items-center gap-2.5 rounded-lg px-2 py-2 transition-colors hover:bg-white/[.05]">
                <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-linear-to-tr from-violet-600 to-violet-400 font-bold text-[10px] text-white">
                    JK
                </div>
                <div class="sb-text min-w-0">
                    <p class="truncate text-xs font-semibold text-white">Jorvan Kleiv</p>
                    <p class="truncate text-[10px] text-dark-text">Administrateur</p>
                </div>
            </div>
        </div>
    </aside>
    <div class="flex min-w-0 flex-1 flex-col overflow-hidden">
        <header class="z-10 flex h-[52px] shrink-0 items-center justify-between border-b border-ink-7 bg-surface px-4">
            <div class="flex items-center gap-1">
                <button onclick="toggleSidebar()"
                        class="flex h-8 w-8 items-center justify-center rounded-lg text-ink-5 transition-colors hover:bg-ink-8 hover:text-ink"
                        title="Réduire / Agrandir">
                    <iconify-icon icon="solar:sidebar-minimalistic-linear" class="text-base"></iconify-icon>
                </button>
                <div class="mx-1 h-4 w-px bg-ink-7"></div>
                <div class="flex items-center gap-1.5 text-xs text-ink-5">
                    <span>Admin</span>
                    <iconify-icon icon="solar:alt-arrow-right-linear" class="text-[9px]"></iconify-icon>
                    <span id="topbar-title" class="font-semibold text-ink">Vue d'ensemble</span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                <button class="relative flex h-8 w-8 items-center justify-center rounded-lg border border-ink-7 text-ink-4 transition-colors hover:bg-ink-8">
                    <iconify-icon icon="solar:bell-linear" class="text-base"></iconify-icon>
                    <span class="absolute top-1.5 right-1.5 h-1.5 w-1.5 rounded-full border border-white bg-red-500"></span>
                </button>
                <div class="flex h-[30px] w-[30px] cursor-pointer items-center justify-center rounded-lg bg-linear-to-tr from-violet-600 to-violet-400 font-bold text-[10px] text-white">
                    JK
                </div>
            </div>
        </header>

        @RenderBody()
    </div><!-- /main -->
    <!-- ════════════════════════════════════════
         MODALS
    ════════════════════════════════════════ -->
    <div id="modal-warn-user" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-warn-user')"></div>
        <div class="modal-box max-w-md">
            <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-amber-200 bg-amber-50">
                    <iconify-icon icon="solar:danger-triangle-bold" class="text-lg text-amber-500"></iconify-icon>
                </div>
                <div class="flex-1">
                    <p class="font-syne text-sm font-bold text-ink">Envoyer un avertissement</p>
                    <p id="warn-name" class="text-xs text-ink-5"></p>
                </div>
                <button onclick="closeModal('modal-warn-user')"
                        class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                    ✕
                </button>
            </div>
            <div class="flex flex-col gap-3 p-5">
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Raison</label><select class="rounded-btn w-full cursor-pointer border border-ink-7 bg-ink-9 px-3 py-2 text-xs outline-none">
                        <option>Contenu inapproprié</option>
                        <option>Spam</option>
                        <option>Comportement abusif</option>
                        <option>Deal frauduleux</option>
                        <option>Autre</option>
                    </select>
                </div>
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                        Message
                        optionnel
                    </label><textarea rows="3" placeholder="Précisez le motif…"
                                      class="rounded-btn w-full resize-none border border-ink-7 bg-ink-9 px-3 py-2 text-xs transition-colors outline-none placeholder:text-ink-5 focus:border-ink-5"></textarea>
                </div>
            </div>
            <div class="flex gap-2 px-5 pb-5">
                <button onclick="closeModal('modal-warn-user')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Annuler
                </button>
                <button onclick="showToast('Avertissement envoyé ✓','orange');closeModal('modal-warn-user')"
                        class="rounded-btn flex-1 bg-amber-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-amber-600">
                    Envoyer
                </button>
            </div>
        </div>
    </div>

    <div id="modal-ban-user" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-ban-user')"></div>
        <div class="modal-box max-w-md">
            <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-red-200 bg-red-50">
                    <iconify-icon icon="solar:lock-password-bold" class="text-lg text-red-500"></iconify-icon>
                </div>
                <div class="flex-1">
                    <p class="font-syne text-sm font-bold text-ink">Bannir l'utilisateur</p>
                    <p id="ban-name" class="text-xs text-ink-5"></p>
                </div>
                <button onclick="closeModal('modal-ban-user')"
                        class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                    ✕
                </button>
            </div>
            <div class="flex flex-col gap-3 p-5">
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Raison</label><select class="rounded-btn w-full cursor-pointer border border-ink-7 bg-ink-9 px-3 py-2 text-xs outline-none">
                        <option>Comportement abusif répété</option>
                        <option>Spam massif</option>
                        <option>Deal frauduleux</option>
                        <option>Violation des CGU</option>
                    </select>
                </div>
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Durée</label>
                    <div class="grid grid-cols-4 gap-1.5" id="duree-btns">
                        <button onclick="selectDuree(this)"
                                class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                            7j
                        </button>
                        <button onclick="selectDuree(this)"
                                class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                            30j
                        </button>
                        <button onclick="selectDuree(this)"
                                class="rounded-btn border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-all hover:border-ink-5">
                            90j
                        </button>
                        <button onclick="selectDuree(this)"
                                class="rounded-btn border border-red-200 bg-red-50 py-2 text-xs font-semibold text-red-600 transition-all hover:bg-red-100">
                            ∞
                        </button>
                    </div>
                </div>
                <label class="flex cursor-pointer items-center gap-2 text-xs">
                    <input type="checkbox" checked
                           class="accent-ink">Notifier par email
                </label>
            </div>
            <div class="flex gap-2 px-5 pb-5">
                <button onclick="closeModal('modal-ban-user')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Annuler
                </button>
                <button onclick="showToast('Utilisateur banni ✓','red');closeModal('modal-ban-user')"
                        class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600">
                    Confirmer
                </button>
            </div>
        </div>
    </div>

    <div id="modal-delete-user" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-delete-user')"></div>
        <div class="modal-box max-w-sm">
            <div class="flex items-center gap-3 border-b border-ink-7 p-5">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl border border-red-200 bg-red-50">
                    <iconify-icon icon="solar:trash-bin-minimalistic-bold" class="text-lg text-red-500"></iconify-icon>
                </div>
                <div class="flex-1">
                    <p class="font-syne text-sm font-bold text-ink">Supprimer le compte</p>
                    <p class="text-xs font-semibold text-red-500">Action irréversible</p>
                </div>
                <button onclick="closeModal('modal-delete-user')"
                        class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                    ✕
                </button>
            </div>
            <div class="flex flex-col gap-3 p-5">
                <p class="rounded-btn border border-red-100 bg-red-50 px-3 py-2.5 text-xs text-ink-3">
                    Tous les deals,
                    commentaires et données seront définitivement supprimés.
                </p>
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                        Tapez <strong class="text-ink">SUPPRIMER</strong> pour confirmer
                    </label><input id="del-input" type="text"
                                   oninput="checkDel(this)" placeholder="SUPPRIMER"
                                   class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2 font-mono text-xs transition-colors outline-none placeholder:text-ink-6 focus:border-red-400">
                </div>
            </div>
            <div class="flex gap-2 px-5 pb-5">
                <button onclick="closeModal('modal-delete-user')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Annuler
                </button>
                <button id="btn-del" disabled
                        onclick="showToast('Compte supprimé','red');closeModal('modal-delete-user');document.getElementById('del-input').value='';checkDel({value:''})"
                        class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600 disabled:cursor-not-allowed disabled:opacity-30">
                    Supprimer
                </button>
            </div>
        </div>
    </div>

    <div id="modal-invite" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-invite')"></div>
        <div class="modal-box max-w-sm">
            <div class="flex items-center justify-between border-b border-ink-7 p-5">
                <p class="font-syne text-sm font-bold text-ink">Inviter un utilisateur</p>
                <button onclick="closeModal('modal-invite')"
                        class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                    ✕
                </button>
            </div>
            <div class="flex flex-col gap-3 p-5">
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">Email</label><input type="email" placeholder="nom@exemple.com"
                                                                                                                              class="rounded-btn w-full border border-ink-7 bg-ink-9 px-3 py-2 text-xs transition-colors outline-none focus:border-ink-5">
                </div>
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                        Rôle
                        initial
                    </label><select class="rounded-btn w-full cursor-pointer border border-ink-7 bg-ink-9 px-3 py-2 text-xs outline-none">
                        <option>Utilisateur</option>
                        <option>Modérateur</option>
                        <option>Marchand</option>
                        <option>Administrateur</option>
                    </select>
                </div>
                <label class="flex cursor-pointer items-center gap-2 text-xs">
                    <input type="checkbox" checked
                           class="accent-ink">Envoyer un email d'invitation
                </label>
            </div>
            <div class="flex gap-2 px-5 pb-5">
                <button onclick="closeModal('modal-invite')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Annuler
                </button>
                <button onclick="showToast('Invitation envoyée ✓','green');closeModal('modal-invite')"
                        class="rounded-btn flex flex-1 items-center justify-center gap-1.5 bg-ink py-2 text-xs font-semibold text-white transition-colors hover:bg-ink-2">
                    <iconify-icon icon="solar:send-linear"></iconify-icon>Inviter
                </button>
            </div>
        </div>
    </div>

    <div id="modal-confirm" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-confirm')"></div>
        <div class="modal-box max-w-sm p-5">
            <p class="font-syne mb-1.5 text-sm font-bold text-ink">Confirmer la suppression</p>
            <p class="mb-4 text-xs text-ink-4">Cette action est irréversible.</p>
            <div class="flex gap-2">
                <button onclick="closeModal('modal-confirm')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Annuler
                </button>
                <button onclick="showToast('Supprimé ✓','red');closeModal('modal-confirm')"
                        class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600">
                    Supprimer
                </button>
            </div>
        </div>
    </div>

    <div id="modal-marchand" class="modal-wrap hidden">
        <div class="modal-bg" onclick="closeModal('modal-marchand')"></div>
        <div class="modal-box max-w-md">
            <div class="flex items-center justify-between border-b border-ink-7 p-5">
                <p class="font-syne text-sm font-bold text-ink">Dossier — Amazon France</p>
                <button onclick="closeModal('modal-marchand')"
                        class="flex h-7 w-7 items-center justify-center rounded-lg bg-ink-8 text-xs text-ink-4 transition-colors hover:bg-ink-7">
                    ✕
                </button>
            </div>
            <div class="flex flex-col gap-3 p-5">
                <div class="grid grid-cols-2 gap-2">
                    <div class="rounded-btn border border-ink-7 bg-ink-9 p-3">
                        <p class="mb-1 font-bold tracking-wider text-[10px] text-ink-5 uppercase">SIRET</p>
                        <p class="font-mono text-xs font-semibold">12345678901234</p>
                    </div>
                    <div class="rounded-btn border border-ink-7 bg-ink-9 p-3">
                        <p class="mb-1 font-bold tracking-wider text-[10px] text-ink-5 uppercase">Statut BODACC</p>
                        <p class="text-xs font-semibold text-green-600">✓ Actif</p>
                    </div>
                    <div class="rounded-btn border border-ink-7 bg-ink-9 p-3">
                        <p class="mb-1 font-bold tracking-wider text-[10px] text-ink-5 uppercase">Raison sociale</p>
                        <p class="text-xs font-semibold">Amazon Europe</p>
                    </div>
                    <div class="rounded-btn border border-ink-7 bg-ink-9 p-3">
                        <p class="mb-1 font-bold tracking-wider text-[10px] text-ink-5 uppercase">Site web</p>
                        <p class="text-xs font-semibold text-blue-600">amazon.fr</p>
                    </div>
                </div>
                <div>
                    <label class="mb-1.5 block font-bold tracking-wider text-[10px] text-ink-5 uppercase">
                        Note
                        interne
                    </label><textarea rows="2" placeholder="Ajouter une note…"
                                      class="rounded-btn w-full resize-none border border-ink-7 bg-ink-9 px-3 py-2 text-xs transition-colors outline-none placeholder:text-ink-5 focus:border-ink-5"></textarea>
                </div>
            </div>
            <div class="flex gap-2 px-5 pb-5">
                <button onclick="closeModal('modal-marchand')"
                        class="rounded-btn flex-1 border border-ink-7 py-2 text-xs font-semibold text-ink-4 transition-colors hover:bg-ink-8">
                    Fermer
                </button>
                <button onclick="showToast('Refusé','red');closeModal('modal-marchand')"
                        class="rounded-btn flex-1 bg-red-500 py-2 text-xs font-semibold text-white transition-colors hover:bg-red-600">
                    Refuser
                </button>
                <button onclick="showToast('Marchand approuvé ✓','green');closeModal('modal-marchand')"
                        class="rounded-btn flex flex-1 items-center justify-center gap-1 bg-green-600 py-2 text-xs font-semibold text-white transition-colors hover:bg-green-700">
                    <iconify-icon icon="solar:check-circle-linear"></iconify-icon>Approuver
                </button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toast">
        <div class="shadow-modal flex items-center gap-2.5 rounded-xl bg-ink px-4 py-2.5 text-white">
            <iconify-icon id="toast-icon" class="shrink-0 text-base"></iconify-icon>
            <span id="toast-msg" class="text-xs font-semibold"></span>
        </div>
    </div>

    <script src="/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>